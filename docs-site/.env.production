# Canonical production site URL for the Cloudflare Workers deployment.
# Consumed by src/lib/env.ts (NEXT_PUBLIC_SITE_URL takes priority over the
# legacy Vercel-injected fallbacks) to generate sitemap.xml, robots.txt,
# canonical tags, OG URLs, and llms.txt absolute links.
NEXT_PUBLIC_SITE_URL=https://www.formualizer.dev
