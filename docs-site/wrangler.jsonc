{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "formualizer-docs",
	// Same Cloudflare account as formualizer-web.
	"account_id": "4597ed26ea326a831e21b9898376ef59",
	"compatibility_date": "2026-07-03",
	"assets": {
		"directory": "./out",
		"not_found_handling": "404-page"
	}
	// No `routes` / custom_domain: deploy to workers.dev only.
	// The orchestrator performs the www.formualizer.dev cutover afterward.
}
